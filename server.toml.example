# DAPRS Server 配置
[server]
# 协议版本
version = 1
# 绑定地址
bind = "0.0.0.0:8080"
# Server/Agent 认证 token
api_token = "TOKEN"
# keepalive time in seconds
alive = 60
# sqlite database path
db_path = "daprs.db"
# Agent request timeout in seconds
agent_timeout_secs = 15
servers = [
    { name = "local", address = "127.0.0.1:9813" },
    # { name = "server2", address = "IP_ADDRESS:PORT" },
]

# RateLimit
[server.rate_limit.auth]
window_secs = 10
max_requests = 5

[server.rate_limit.api]
window_secs = 60
max_requests = 100

## WebUI 配置
[web]
# OAuth 客户端 ID
client_id = "KEY"
# OAuth 客户端密钥
client_secret = "SECRET"
# OAuth Provider 发现地址
oauth_provider = "https://auth.iedon.net/.well-known/openid-configuration"
# OAuth 回调地址（指向 Server API）
redirect_uri = "http://localhost:8080/api/login/callback"
# 前端地址（用于 CORS 和登录后重定向）
frontend_origin = "http://localhost:5173"
